# ============================================================
# Environment Variables for Regional Slang Lexicon Experiments
# ============================================================
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
# Then load before running:
#   set -a && source .env && set +a    (bash / Git Bash)
#   or use python-dotenv in your script.

# ── LLM API Keys (REQUIRED for real LLM experiments) ──
# Both oracle and evaluator share the same key if using DeepSeek.
# For cross-model evaluation, set a different EVAL_LLM_API_KEY below.
OPENAI_API_KEY=sk-your-deepseek-api-key-here

# ── API Base URLs (DeepSeek by default) ──
OPENAI_BASE_URL=https://api.deepseek.com
# ── Model Names (defaults shown; override to switch versions) ──
# LLM_MODEL=deepseek-v4-flash          # Oracle (selection)
# EVAL_LLM_MODEL=deepseek-v4-pro       # Evaluator (independent assessment)

# ── Cross-model evaluation examples ──
# GLM / Zhipu AI:
#   EVAL_LLM_MODEL=glm-5
#   EVAL_LLM_API_KEY=your-glm-api-key-here
#   EVAL_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GPT-4o:
#   EVAL_LLM_MODEL=gpt-4o
#   EVAL_LLM_API_KEY=sk-your-openai-key
#   EVAL_LLM_BASE_URL=https://api.openai.com/v1

# ── Python hash seed (REQUIRED for reproducible experiments) ──
# Must be set BEFORE Python starts — the interpreter reads it at startup.
# Setting it inside Python (os.environ) has NO EFFECT.
PYTHONHASHSEED=42

# ── HuggingFace Mirror (China mainland users) ──
# Set to a domestic mirror if huggingface.co is unreachable.
HF_ENDPOINT=https://hf-mirror.com

# ── Optional ──
# TRANSFORMERS_VERBOSITY=error     # Reduce transformers log noise
# CURL_CA_BUNDLE=                  # Only set on legacy Linux with outdated CA certs